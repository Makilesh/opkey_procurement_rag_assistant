# --- LLM (Gemini via LiteLLM) ---
GEMINI_API_KEY=your-gemini-api-key-here
MODEL_MAIN=gemini/gemini-3.5-flash
MODEL_CHEAP=gemini/gemini-3.1-flash-lite
RPM_MAIN=10
RPM_CHEAP=15

# --- Auth ---
JWT_SECRET=replace-with-a-long-random-string
DEMO_USERNAME=demo
DEMO_PASSWORD=demo123

# --- Service ports (host side) ---
API_PORT=8000
UI_PORT=7860

# --- Embedding / reranking ---
EMBEDDING_DEVICE=cpu
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
EMBED_BATCH_SIZE=8

# --- Chat / retrieval tuning ---
HISTORY_WINDOW_TURNS=6
MIN_RERANK_SCORE=0.25

# --- Session store ---
REDIS_URL=redis://localhost:6379/0

# --- Optional local Ollama fallback (local dev only, never in Docker) ---
OLLAMA_FALLBACK_ENABLED=false
OLLAMA_MODEL=qwen2.5:14b-instruct-q4_k_m
OLLAMA_BASE_URL=http://localhost:11434
